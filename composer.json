{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/react-starter-kit",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "inertiajs/inertia-laravel": "^3.0",
        "laravel/fortify": "^1.34",
        "laravel/framework": "^13.7",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^3.0",
        "laravel/wayfinder": "^0.1.14",
        "spatie/laravel-medialibrary": "^11.22"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.2",
        "laravel/pail": "^1.2.5",
        "laravel/pao": "^1.0.6",
        "laravel/pint": "^1.27",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.9.3",
        "pestphp/pest": "^4.7",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/extension-installer": "*",
        "phpstan/phpstan-deprecation-rules": "*",
        "phpstan/phpstan-strict-rules": "*",
        "rector/rector": "^2.4",
        "spaze/phpstan-disallowed-calls": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "pnpm install",
            "pnpm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "pnpx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"pnpm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "format": [
            "rector",
            "pint --parallel",
            "pnpm run format"
        ],
        "format:check": [
            "rector --dry-run",
            "pint --parallel --test",
            "pnpm run format:check"
        ],
        "lint": [
            "php -d memory_limit=-1 vendor/bin/phpstan",
            "pnpm run typecheck",
            "pnpm run lint"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test",
            "pnpm run test"
        ],
        "check": [
            "@format",
            "@lint"
        ],
        "coverage": "php -d memory_limit=-1 vendor/bin/pest --type-coverage --min=100",
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@format",
            "@lint",
            "@test"
        ],
        "clean": [
            "@php artisan optimize:clear",
            "rm -rf public/build",
            "rm -rf resources/js/actions resources/js/routes resources/js/wayfinder"
        ],
        "db:seed": "@php artisan migrate:fresh --seed --force",
        "db:reset": "@php scripts/db-reset.php",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "repositories": [
        {
            "name": "packagist",
            "type": "composer",
            "url": "https://repo.packagist.org"
        }
    ]
}
