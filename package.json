        "@types/node": "^25.9.1",
        "babel-plugin-react-compiler": "^1.0.0",
        "jsdom": "^29.1.1",
        "oxfmt": "^0.51.0",
        "oxlint": "^1.66.0",
        "vitest": "^4.1.7"
    },
