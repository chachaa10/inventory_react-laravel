{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "build:ssr": "vite build && vite build --ssr",
        "dev": "vite",
        "format": "oxfmt",
        "format:check": "oxfmt --check",
        "lint": "oxlint",
        "lint:check": "oxlint",
        "lint:fix": "oxlint --fix",
        "clean": "rm -rf node_modules/.vite",
        "clean:all": "npm run clean && rm -rf node_modules",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "check": "npm run format && npm run lint && npm run typecheck && npm run test:run && npm run build"
    },
    "devDependencies": {
        "@laravel/vite-plugin-wayfinder": "^0.1.7",
